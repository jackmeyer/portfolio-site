# Copy to .env and fill in. Never commit .env.

# Directory holding site.db and uploads/ (mounted volume in Docker).
DATA_DIR=/data

# First-boot admin bootstrap: used only when the users table is empty.
# Safe to remove after first login.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Canonical public URL, used for RSS/sitemap/OG tags.
PUBLIC_SITE_URL=https://example.com

# Site name shown in page titles and window chrome.
PUBLIC_SITE_TITLE=My Desktop
